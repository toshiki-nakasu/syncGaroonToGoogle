{
    // # devcontainer.json sample
    // recommend: Do not sort json
    // ## To create image
    "name": "syncGaroonToGoogle",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopContainer",
    "privileged": true,
    "init": true,

    // ## From base image
    "build": {
        "dockerfile": "./Dockerfile",
        "args": {
            "TAG": "bookworm-slim"
        }
    },

    // ## Resources
    // warning: Can not use Env
    "mounts": [
        {
            "type": "bind",
            "source": "${localWorkspaceFolder}",
            "target": "${containerWorkspaceFolder}"
        },
        {
            "type": "volume",
            "source": "docker_volume",
            "target": "/var/lib/docker"
        },
        {
            "type": "volume",
            "source": "sync-garoon-to-google-node_modules",
            "target": "/workspace/sync-garoon-to-google/node_modules"
        }
    ],
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "username": "node"
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/git-lfs:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/aws-cli:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24"
        }
        // "ghcr.io/devcontainers/features/python:1": {
        //     "version": "3.12"
        // },
        // "ghcr.io/va-h/devcontainers-features/uv:1": {}
    },

    // ## Environment
    "remoteUser": "node",
    "containerEnv": {
        "TZ": "Asia/Tokyo",
        "LANG": "C.UTF-8"
    },
    "remoteEnv": {
        // "AWS_PROFILE": "",
        // "AWS_SDK_LOAD_CONFIG": "1"
    },
    "forwardPorts": [
        // 4566, 4571, 5601
    ],

    // ## Container command
    // warning: To use .sh you need mount
    // info: key is output stage
    "overrideCommand": true,
    "postCreateCommand": {
        "chown_node_modules": "sudo chown -R node:node /workspace/sync-garoon-to-google/node_modules && bash script/postCreate.sh"
    },
    "postStartCommand": {
        "add_git_safe_directory": "git config --global --add safe.directory /workspace"
    },

    // ## IDE
    "customizations": {
        "vscode": {
            "extensions": [],
            "settings": {}
        }
    }
}
