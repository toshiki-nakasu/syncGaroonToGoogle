{
    "name": "sync-garoon-to-google",
    "version": "1.0.0",
    "description": "Sync Garoon schedule to Google Calendar",
    "main": "index.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "setup": "clasp login && clasp create --type api",
        "clone": "clasp clone",
